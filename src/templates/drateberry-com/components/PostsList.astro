---
import { getReadingTime } from "../../../utils/reading-time";

interface Props {
	totalCount: number;
	postsWithTags: Array<{
		post: {
			id: string;
			data: {
				title: string;
				excerpt?: string;
				publishedAt?: Date | null;
				content: any;
				bylines?: Array<{
					byline: {
						avatarMediaId?: string;
						displayName: string;
					};
				}>;
			};
		};
		tags: Array<{ slug: string; label: string }>;
		bylines: Array<{
			byline: {
				avatarMediaId?: string;
				displayName: string;
			};
		}>;
	}>;
}

const { totalCount, postsWithTags } = Astro.props;

const formatDate = (date: Date) =>
	date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
---

<div class="posts-page">
	<header class="page-header">
		<h1 class="page-title">All Posts</h1>
		<p class="page-description">
			{totalCount}
			{totalCount === 1 ? "article" : "articles"}
		</p>
	</header>

	{
		postsWithTags.length === 0 ? (
			<p class="empty">No posts yet.</p>
		) : (
			<div class="posts-list">
				{postsWithTags.map(({ post, tags, bylines }) => (
					<article class="post-item">
						<a href={`/posts/${post.id}`} class="post-link">
							<div class="post-meta">
								{bylines.length > 0 && (
									<>
										<span class="post-byline-name">
											{bylines[0].byline.displayName}
										</span>
										{bylines.length > 1 && (
											<span class="byline-more">+{bylines.length - 1}</span>
										)}
										<span class="meta-sep">/</span>
									</>
								)}
								{post.data.publishedAt && (
									<time>{formatDate(post.data.publishedAt)}</time>
								)}
								{post.data.publishedAt && <span class="meta-sep">/</span>}
								<span>{getReadingTime(post.data.content)} min read</span>
							</div>
							<h2 class="post-title">{post.data.title}</h2>
							{post.data.excerpt && (
								<p class="post-excerpt">{post.data.excerpt}</p>
							)}
						</a>
						{tags.length > 0 && (
							<div class="post-tags">
								{tags.slice(0, 3).map((t) => (
									<a href={`/tag/${t.slug}`} class="post-tag">
										{t.label}
									</a>
								))}
							</div>
						)}
					</article>
				))}
			</div>
		)
	}
</div>

<style>
	.posts-page {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	.page-header {
		margin-bottom: var(--spacing-12);
	}

	.page-title {
		font-family: var(--font-mono);
		font-size: var(--font-size-4xl);
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-2);
	}

	.page-description {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.empty {
		font-family: var(--font-mono);
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.posts-list {
		display: flex;
		flex-direction: column;
	}

	.post-item {
		padding: var(--spacing-8) 0;
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.post-item:first-child {
		padding-top: 0;
	}

	.post-item:last-child {
		border-bottom: none;
	}

	.post-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		margin-bottom: var(--spacing-2);
	}

	.meta-sep {
		color: var(--color-border);
	}

	.post-byline-name {
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.byline-more {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.post-title {
		font-family: var(--font-mono);
		font-size: var(--font-size-2xl);
		font-weight: 600;
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-snug);
		margin-bottom: var(--spacing-2);
		transition: color var(--transition-fast);
	}

	.post-link:hover .post-title {
		color: var(--color-accent);
	}

	.post-excerpt {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-4);
	}

	.post-tag {
		display: inline-block;
		padding: var(--tag-padding-y) var(--spacing-3);
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
		background: var(--color-surface);
		border-radius: var(--radius);
		text-decoration: none;
		transition:
			color var(--transition-fast),
			background var(--transition-fast);
	}

	.post-tag:hover {
		color: var(--color-accent);
		background: var(--color-border);
	}

	@media (max-width: 600px) {
		.posts-page {
			padding: var(--spacing-6) var(--spacing-4) var(--spacing-12);
		}

		.page-title {
			font-size: var(--font-size-3xl);
		}

		.post-title {
			font-size: var(--font-size-xl);
		}
	}
</style>
